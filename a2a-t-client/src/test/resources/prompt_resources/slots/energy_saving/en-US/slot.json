{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "site": {
      "type": "string",
      "description": "Site name",
      "examples": ["Site A"],
      "pattern": "^Site .+"
    },
    "additional_notes": {
      "type": "string",
      "description": "Additional notes",
      "examples": ["critical"]
    },
    "limit": {
      "type": "integer",
      "description": "Limit count",
      "minimum": 1,
      "maximum": 10
    },
    "severity": {
      "type": "string",
      "description": "Severity level",
      "enum": ["low", "medium", "high"]
    }
  },
  "required": ["site"]
}
